{
  "manifest_version": 3,
  "name": "Claude Usage Meter",
  "version": "2.0.0",
  "description": "Live session + weekly token counter for Claude. Model-aware msgs-left, reset countdowns, handoff to ChatGPT/Gemini/Grok with auto-paste. No API keys, no servers.",
  "permissions": ["storage","alarms","scripting","tabs","clipboardWrite"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://grok.x.com/*",
    "https://x.com/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    { "matches": ["https://claude.ai/*"], "js": ["content.js"], "css": ["styles.css"], "run_at": "document_idle" },
    { "matches": ["https://chatgpt.com/*","https://chat.openai.com/*"], "js": ["inject-chatgpt.js"], "run_at": "document_idle" },
    { "matches": ["https://gemini.google.com/*"], "js": ["inject-gemini.js"], "run_at": "document_idle" },
    { "matches": ["https://grok.x.com/*","https://x.com/i/grok*"], "js": ["inject-grok.js"], "run_at": "document_idle" }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
    "default_title": "Claude Usage Meter"
  },
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "web_accessible_resources": [
    { "resources": ["inject.js"], "matches": ["https://claude.ai/*"] }
  ]
}
